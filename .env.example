# URL canonique de production (sans slash final)
NEXT_PUBLIC_SITE_URL=https://guidegta6.fr

# Google AdSense — identifiant client (format ca-pub-XXXXXXXXXXXXXXXX)
# Laisser vide tant que le compte AdSense n'est pas approuve : des emplacements
# "placeholder" s'affichent a la place des vraies pubs.
NEXT_PUBLIC_ADSENSE_CLIENT=

# Tag d'affiliation Amazon France (Partenaires Amazon), ex: guidegta6-21
NEXT_PUBLIC_AMAZON_TAG=

# Verification Google Search Console (contenu de la balise meta google-site-verification)
NEXT_PUBLIC_GSC_VERIFICATION=
